{
  "name": "wazoapp",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "lint": "pnpm -r lint",
    "dev:wazopets": "pnpm -C wazopets dev",
    "dev:admin": "pnpm -C wazopets-admin dev",
    "dev:backend": "pnpm -C packages/convex-backend dev",
    "deploy:backend": "pnpm -C packages/convex-backend deploy",
    "convex:codegen": "pnpm -C packages/convex-backend codegen",
    "gen-api": "pnpm -C wazopets gen-api",
    "gen-api-admin": "pnpm -C wazopets gen-api-admin"
  }
}

